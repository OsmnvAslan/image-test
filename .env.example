# Vision captioning (style fingerprint + product description). Optional.
# Without it, the app falls back to a deterministic style template + generic product
# descriptor (reduced per-product variation). See PLAN.md §7.
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Failover image provider (Together AI free FLUX). Optional.
# Without it, the failover provider is a deterministic mock (still proves failover).
TOGETHER_API_KEY=

# Concurrency limit for the fan-out pool (default 3).
MAX_CONCURRENCY=3
